{
  "manifest_version": 3,
  "name": "Tilda Space AI",
  "version": "1.0.0",
  "description": "AI-ассистент для создания блоков на Tilda с помощью Gemini",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://tilda.cc/*",
    "https://*.tilda.cc/*",
    "https://tilda.ru/*",
    "https://*.tilda.ru/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tilda Space AI"
  },
  "content_scripts": [
    {
      "matches": ["https://tilda.cc/*", "https://*.tilda.cc/*", "https://tilda.ru/*", "https://*.tilda.ru/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
